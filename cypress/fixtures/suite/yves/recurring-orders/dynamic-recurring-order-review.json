{
  "data": {
    "type": "dynamic-fixtures",
    "attributes": {
      "synchronize": true,
      "operations": [
        {
          "type": "helper",
          "name": "haveCompany",
          "key": "company",
          "arguments": [{ "status": "approved", "is_active": true }]
        },
        {
          "type": "helper",
          "name": "haveCompanyBusinessUnit",
          "key": "businessUnit",
          "arguments": [{ "fk_company": "#company.id_company" }]
        },
        {
          "type": "helper",
          "name": "havePermissionByKey",
          "key": "placeOrderPermission",
          "arguments": ["PlaceOrderPermissionPlugin"]
        },
        {
          "type": "helper",
          "name": "haveCompanyRoleWithPermissions",
          "key": "buyerRole",
          "arguments": [{ "fk_company": "#company.id_company" }, ["#placeOrderPermission"]]
        },
        {
          "type": "helper",
          "name": "haveFullProduct",
          "key": "product",
          "arguments": [{}, { "idTaxSet": 1 }]
        },
        {
          "type": "transfer",
          "name": "StoreTransfer",
          "key": "store",
          "arguments": { "id_store": 1, "name": "DE", "defaultCurrencyIsoCode": "EUR" }
        },
        {
          "type": "helper",
          "name": "havePriceProduct",
          "arguments": [
            {
              "skuProductAbstract": "#product.abstract_sku",
              "skuProduct": "#product.sku",
              "moneyValue": { "netAmount": 40000, "grossAmount": 50000 }
            }
          ]
        },
        {
          "type": "helper",
          "name": "haveProductInStockForStore",
          "arguments": ["#store", { "sku": "#product.sku", "isNeverOutOfStock": "1" }]
        },
        {
          "type": "helper",
          "name": "haveConfirmedCustomer",
          "key": "buyer",
          "arguments": [{ "registered": "2025-01-01", "password": "change123", "locale_name": "en_US" }]
        },
        {
          "type": "builder",
          "name": "CompanyRoleCollectionBuilder",
          "key": "buyerRoleCollection",
          "arguments": { "roles": ["#buyerRole"] }
        },
        {
          "type": "helper",
          "name": "haveCompanyUser",
          "key": "buyerCompanyUser",
          "arguments": [
            {
              "customer": "#buyer",
              "fk_company": "#company.id_company",
              "company_role_collection": ["#buyerRoleCollection"],
              "fk_company_business_unit": "#businessUnit.id_company_business_unit"
            }
          ]
        },
        {
          "type": "helper",
          "name": "assignCompanyRoles",
          "arguments": ["#buyerCompanyUser", ["#buyerRole"]]
        },
        {
          "type": "helper",
          "name": "haveRecurringSchedule",
          "key": "schedule",
          "arguments": [
            "#buyer.id_customer",
            {
              "name": "Review Test Order",
              "cadence_type": "monthly",
              "status": "review_required",
              "build_quote_data": true,
              "payment_method": "dummyPaymentInvoice",
              "store_name": "DE",
              "currency_iso_code": "EUR",
              "price_mode": "GROSS_MODE",
              "first_trigger_date": "2026-07-01",
              "next_trigger_date": "2026-07-01"
            }
          ]
        },
        {
          "type": "helper",
          "name": "haveRecurringScheduleItem",
          "key": "scheduleItem",
          "arguments": [
            "#schedule.id_recurring_schedule",
            {
              "sku": "#product.sku",
              "quantity": 1,
              "reference_gross_price": 30000,
              "reference_net_price": 25000,
              "build_item_data": true
            }
          ]
        }
      ]
    }
  }
}
