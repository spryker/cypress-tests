    "attributes": {
      "synchronize": true,
      "operations": [
        {
          "type": "helper",
          "name": "haveCompany",
          "key": "company",
          "arguments": [{ "status": "approved", "is_active": true }]
        },
        {
          "type": "helper",
          "name": "haveCompanyBusinessUnit",
          "key": "businessUnit",
          "arguments": [{ "fk_company": "#company.id_company" }]
        },
        {
          "type": "helper",
          "name": "havePermissionByKey",
          "key": "placeOrderPermission",
          "arguments": ["PlaceOrderPermissionPlugin"]
        },
        {
          "type": "helper",
          "name": "haveCompanyRoleWithPermissions",
          "key": "buyerRole",
          "arguments": [{ "fk_company": "#company.id_company" }, ["#placeOrderPermission"]]
