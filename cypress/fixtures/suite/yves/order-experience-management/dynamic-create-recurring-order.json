          "type": "helper",
          "name": "assignCompanyRoles",
          "arguments": ["#buyerForCreditCardCompanyUser", ["#buyerRole"]]
        },
        {
          "type": "helper",
          "name": "havePersistentQuote",
          "key": "quoteForCreditCard",
          "arguments": [
            {
              "customer": "#buyerForCreditCard",
              "items": [{ "sku": "#product.sku", "abstractSku": "#product.abstract_sku", "quantity": 1 }]
            },
            true
          ]
        }
      ]
    }
