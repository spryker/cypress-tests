              "productImages": ["#productImage"]
            }
          ]
        },
        {
          "type": "helper",
          "name": "haveShipmentType",
          "key": "shipmentType",
          "arguments": [{ "key": "delivery" }]
        },
        {
          "type": "helper",
          "name": "haveProductConcreteShipmentType",
          "arguments": ["#product", "#shipmentType"]
        },
        {
          "type": "helper",
          "name": "haveConfirmedCustomer",
          "key": "buyer",
          "arguments": [{ "registered": "2025-01-01", "password": "change123", "locale_name": "en_US" }]
        },
        {
          "type": "builder",
          "name": "CompanyRoleCollectionBuilder",
          "key": "buyerRoleCollection",
          "arguments": { "roles": ["#buyerRole"] }
        },
        {
          "type": "helper",
          "name": "haveCompanyUser",
          "key": "buyerCompanyUser",
          "arguments": [
            {
              "customer": "#buyer",
              "fk_company": "#company.id_company",
              "company_role_collection": ["#buyerRoleCollection"],
              "fk_company_business_unit": "#businessUnit.id_company_business_unit"
            }
          ]
        },
        {
          "type": "helper",
          "name": "assignCompanyRoles",
          "arguments": ["#buyerCompanyUser", ["#buyerRole"]]
        },
        {
          "type": "helper",
          "name": "havePersistentQuote",
          "key": "quote",
          "arguments": [
            {
              "customer": "#buyer",
              "items": [{ "sku": "#product.sku", "abstractSku": "#product.abstract_sku", "quantity": 1 }]
            },
            true
          ]
        },
        {
          "type": "helper",
          "name": "haveConfirmedCustomer",
          "key": "buyerForCreditCard",
          "arguments": [{ "registered": "2025-01-01", "password": "change123", "locale_name": "en_US" }]
        },
        {
          "type": "builder",
          "name": "CompanyRoleCollectionBuilder",
          "key": "buyerForCreditCardRoleCollection",
          "arguments": { "roles": ["#buyerRole"] }
        },
        {
          "type": "helper",
          "name": "haveCompanyUser",
          "key": "buyerForCreditCardCompanyUser",
          "arguments": [
            {
              "customer": "#buyerForCreditCard",
              "fk_company": "#company.id_company",
              "company_role_collection": ["#buyerForCreditCardRoleCollection"],
              "fk_company_business_unit": "#businessUnit.id_company_business_unit"
            }
          ]
