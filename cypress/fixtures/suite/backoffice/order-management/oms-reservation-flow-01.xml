<?xml version="1.0"?>
<!--
  Minimal OMS state machine tailored for the reservation Cypress tests
  (cypress/e2e/backoffice/order-management/oms-reservation-flow.cy.ts).

  Purpose:
    - Provide a deterministic, free-of-extra-commands process so the test
      doesn't need to drive the rich DummyPayment01 chain (skip grace period
      → Pay → Skip timeout → skip picking → Ship → Stock update → Close).
    - Cover both reservation flows the test asserts on:
        * happy path → items reach `closed` (non-reserved) via the `complete`
          event, reservation drops to zero.
        * cancellation → items go from `reserved` to `cancelled` via the
          `cancel` event, reservation drops to zero.

  Deployment note:
    Spryker's OMS process loader reads XML files from `config/Zed/oms/` of the
    deployed project (inside the Spryker container that path is `/data/config/Zed/oms`).
    The cypress-tests `cypress/fixtures/` directory is mounted ONLY into the
    cypress-tests container, not into Spryker's `cli`/`zed` containers — so this
    XML cannot be loaded from here directly. The dynamic fixture therefore points
    `configureTestStateMachine`'s `$xmlFolder` at `/data/config/Zed/oms`, and a
    mirrored copy of this file named `OmsReservationFlow01.xml` MUST live in the
    project's `config/Zed/oms/` folder. This file is the canonical source — keep
    `config/Zed/oms/OmsReservationFlow01.xml` in sync with it.
-->
<statemachine
    xmlns="spryker:oms-01"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="spryker:oms-01 http://static.spryker.com/oms-01.xsd"
>

    <process name="OmsReservationFlow01" main="true">

        <states>
            <state name="new" display="oms.state.new">
                <flag>cancellable</flag>
            </state>
            <state name="reserved" reserved="true" display="oms.state.payment-pending">
                <flag>cancellable</flag>
            </state>
            <state name="cancelled" display="oms.state.canceled">
                <flag>exclude from customer</flag>
            </state>
            <state name="closed" display="oms.state.closed"/>
        </states>

        <transitions>
            <transition happy="true">
                <source>new</source>
                <target>reserved</target>
                <event>reserve</event>
            </transition>

            <transition happy="true">
                <source>reserved</source>
                <target>closed</target>
                <event>complete</event>
            </transition>

            <transition>
                <source>new</source>
                <target>cancelled</target>
                <event>cancel</event>
            </transition>

            <transition>
                <source>reserved</source>
                <target>cancelled</target>
                <event>cancel</event>
            </transition>
        </transitions>

        <events>
            <event name="reserve" manual="true"/>
            <event name="complete" manual="true"/>
            <event name="cancel" manual="true"/>
        </events>

    </process>

</statemachine>
